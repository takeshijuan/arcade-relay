# ArcadeRelay — アセット生成APIキー
# コピーして .env を作成: cp .env.example .env
# キーが無い項目はローカル縮退モード（品質低下・音楽はプレースホルダ級）で動作します。
# 詳細: .claude/docs/assets-config.md

# ── 必須（フル品質で動かす場合）─────────────────────────────

# fal.ai — 画像生成の primary（Ideogram V3 透過 / FLUX.2 pro / BiRefNet 背景除去 / LoRA訓練）
# 取得: https://fal.ai/dashboard/keys （プリペイド ~$10 推奨）
FAL_KEY=

# ElevenLabs — SFX (Sound Effects v2) + BGM (Eleven Music)
# 取得: https://elevenlabs.io/ → API Keys
# 重要: 商用利用は Starter プラン($6/mo)以上が必須。Free プランは非商用のみ。
ELEVENLABS_API_KEY=

# ── ピクセルアート案件のみ必須 ──────────────────────────────

# Retro Diffusion — ピクセルアート特化（タイル/スプライトシート/アニメ）
# 取得: https://www.retrodiffusion.ai/ （プリペイド ~$5 推奨）
RETRO_DIFFUSION_API_KEY=

# ── 任意（フェイルオーバー用）───────────────────────────────

# Ideogram 直API（fal障害時の画像フェイルオーバー。seed/style_codes互換）
IDEOGRAM_API_KEY=

# OpenAI（三次フェイルオーバー。gpt-image-1.5 固定 — gpt-image-2 は透過非対応）
OPENAI_API_KEY=

# ── 3D 資産（engine=unity/unreal のみ）─────────────────
# 3D の Primary は Meshy 直API（MESHY_API_KEY 有効時）。第二候補が FAL_KEY 経由の
# fal ホスト版 Meshy、両方失敗時のみ Hunyuan3D/TRELLIS/Rodin/Tripo に縮退
# （contract §10 / assets-config.md 3D ルーティング表）。
# 3D 案件で MESHY_API_KEY 未設定は準必須の欠落として preflight が警告する。
# Free プラン出力は商用不可（Meshy は Pro 以上のみ API キー発行あり）。

# Meshy 直API（text/image-to-3D + auto-rigging + アニメ。Pro $20/mo 以上）
MESHY_API_KEY=

# Tripo 直API（非ヒューマノイドのリギングに強い。Pro 以上）
TRIPO_API_KEY=

# ── 予算 ─────────────────────────────────────────────

# 1ゲームあたりの資産生成予算上限（USD）。MANIFEST.jsonl 合算で強制。
# state/budget.txt が優先。未設定時の既定は 20。
ASSET_BUDGET_USD=20
